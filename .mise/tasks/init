#!/usr/bin/env bash
#MISE description="Bootstrap entry point: install stow, deploy mise config, then run full bootstrap"
#MISE quiet=true
#MISE raw=true
set -eo pipefail

# ─── Helpers ───────────────────────────────────────────────────────────────────

TASK_NAME="init"
# shellcheck source=../../mise/tag-default/.config/mise/tasks/lib/helpers.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../../mise/tag-default/.config/mise/tasks/lib/helpers.sh"

# ─── Step 0: Ensure GitHub token is available ─────────────────────────────────
# Done first so install:runtimes (a `bootstrap` dep, runs before its body) and
# every later `mise install` inherits MISE_GITHUB_TOKEN. Without it, aqua/github/vfox
# tools fail with cryptic 403s after exhausting the 60 req/hr unauth budget.

info "Step 0: GitHub token"
if ! ensure_github_token; then
    warn "No GitHub token found in env (\$MISE_GITHUB_TOKEN/\$GITHUB_TOKEN/\$GH_TOKEN) or via gh CLI."
    warn "mise install will rate-limit on aqua/github/vfox tools (e.g. ripgrep, fzf, gh, neovim)."
    warn "Generate a PAT at https://github.com/settings/tokens (no scopes required for public repos)"
    warn "and re-run with:  export GITHUB_TOKEN=ghp_..."
    if [[ "${DOTFILES_NONINTERACTIVE:-0}" == "1" ]]; then
        warn "Continuing in DOTFILES_NONINTERACTIVE mode (some tools may fail to install)."
    else
        # Offer the interactive recovery path: install gh via mise and run gh auth login.
        prompt_github_auth || true
        if [[ -z "${MISE_GITHUB_TOKEN:-}" ]]; then
            read -rp $'\033[1;34m[INFO]\033[0m   Continue without a token? [y/N] ' answer
            [[ "${answer,,}" =~ ^(y|yes)$ ]] || fail "Aborted — set up gh/GITHUB_TOKEN and re-run."
        fi
    fi
fi

# ─── Step 1: Ensure stow is available ─────────────────────────────────────────

info "Step 1: Ensure stow is available"
if command -v stow &>/dev/null; then
    ok "stow already installed: $(command -v stow) ($(stow --version 2>&1 | head -1))"
else
    INSTALLED=false
    # Refresh apt cache once so the install attempts below don't fail with
    # "Unable to locate package" on a stale or empty index. Cheap on a
    # recently-updated machine; required on a fresh container or after `apt clean`.
    if command -v sudo &>/dev/null && command -v apt-get &>/dev/null; then
        info "Refreshing apt cache..."
        sudo apt-get update -qq || warn "apt-get update failed — install attempts may miss packages"
    fi
    if command -v sudo &>/dev/null; then
        for cmd in "nala install -y stow" "apt-get install -y stow" "dnf install -y stow" "pacman -S --noconfirm stow"; do
            mgr="${cmd%% *}"
            if command -v "$mgr" &>/dev/null; then
                info "Trying: sudo $cmd"
                # shellcheck disable=SC2086
                if sudo $cmd; then
                    INSTALLED=true
                    break
                fi
            fi
        done
    fi

    if [[ "$INSTALLED" == false ]]; then
        info "Package manager failed or unavailable, building from source..."

        # Install minimal build deps for stow
        if command -v apt-get &>/dev/null; then
            STOW_BUILD_DEPS=(build-essential autoconf automake curl perl)
            missing=()
            for pkg in "${STOW_BUILD_DEPS[@]}"; do
                dpkg -s "$pkg" &>/dev/null || missing+=("$pkg")
            done
            if [[ ${missing[*]} ]]; then
                info "Installing stow build dependencies: ${missing[*]}"
                if command -v sudo &>/dev/null; then
                    sudo apt-get install -y "${missing[@]}" || warn "Could not install some build deps"
                else
                    warn "sudo not available — please install: ${missing[*]}"
                fi
            fi
        fi

        command -v perl &>/dev/null || fail "Cannot build stow: 'perl' not found"
        command -v make &>/dev/null || fail "Cannot build stow: 'make' not found"

        STOW_VERSION="2.4.1"
        TMPDIR_STOW="$(mktemp -d)"
        trap 'rm -rf "$TMPDIR_STOW"' EXIT

        info "Downloading stow ${STOW_VERSION}..."
        curl -fSL -o "$TMPDIR_STOW/stow-${STOW_VERSION}.tar.gz" \
            "https://ftp.gnu.org/gnu/stow/stow-${STOW_VERSION}.tar.gz"
        tar xzf "$TMPDIR_STOW/stow-${STOW_VERSION}.tar.gz" -C "$TMPDIR_STOW"
        cd "$TMPDIR_STOW/stow-${STOW_VERSION}"

        info "Configuring with --prefix=$HOME/.local ..."
        ./configure --prefix="$HOME/.local" --quiet

        info "Installing..."
        make install --quiet
        cd "$HOME"

        [[ ":$PATH:" != *":$HOME/.local/bin:"* ]] && export PATH="$HOME/.local/bin:$PATH"
    fi

    command -v stow &>/dev/null || fail "stow installation failed — binary not found in PATH"
    ok_changed "stow installed: $(command -v stow) ($(stow --version 2>&1 | head -1))"
fi

# ─── Step 1.5: Choose mise conf.d exclusions before stow ─────────────────────
# Run the exclude prompt before Step 2 so excluded conf.d files are never
# symlinked into ~/.config/mise/conf.d/. Without this, bootstrap's
# `mise install` would install every tool from every conf.d file before the
# user got a chance to opt out. Invoked directly via bash because the
# `setup:*` task namespace is only discoverable after Step 2 stows mise.

info "Step 1.5: Choose mise conf.d exclusions"
if [[ "${DOTFILES_NONINTERACTIVE:-0}" == "1" ]]; then
    info "DOTFILES_NONINTERACTIVE=1 — keeping all conf.d files"
else
    bash "$HOME/.dotfiles/mise/tag-default/.config/mise/tasks/setup/mise-conf-exclude"
fi

# ─── Step 2: Deploy mise config via stow ──────────────────────────────────────

# Back up conflicting real files/dirs inside ~/.config/mise/
# Recurses through shared dirs (.config) and backs up package-owned contents.
# Uses next_backup_path() from helpers.sh.
backup_mise_conflicts() {
    local pkg_dir="$1" # source dir in stow package
    local target="$2"  # corresponding target dir

    for entry in "$pkg_dir"/.* "$pkg_dir"/*; do
        [[ -e "$entry" ]] || continue
        local name
        name="$(basename "$entry")"
        [[ "$name" == "." || "$name" == ".." ]] && continue

        local target_path="$target/$name"
        [[ -e "$target_path" ]] || continue # no conflict
        [[ -L "$target_path" ]] && continue # already a symlink, skip

        if [[ -f "$target_path" ]]; then
            local bak_path
            bak_path="$(next_backup_path "$target_path")"
            mv "$target_path" "$bak_path"
            info "  Backed up: $target_path -> $bak_path"
        elif [[ -d "$entry" && -d "$target_path" ]]; then
            # .config is shared — recurse into it; mise-owned dirs get backed up wholly
            if [[ "$name" == ".config" ]]; then
                backup_mise_conflicts "$entry" "$target_path"
            else
                local bak_path
                bak_path="$(next_backup_path "$target_path")"
                mv "$target_path" "$bak_path"
                info "  Backed up: $target_path -> $bak_path"
            fi
        fi
    done
}

info "Step 2: Deploy mise config via stow"
cd "$HOME/.dotfiles"
mkdir -p "$HOME/.config"

# Honor .mise-conf-exclude if present (re-runs after the user opted out of
# conf files). Two non-obvious gotchas this guards against:
#   1. Stow folds .config/mise/ into a single symlink (mise is the only
#      package contributing to that path), which makes per-file --ignore
#      irrelevant: every conf.d file is reachable through the folded
#      symlink. Pass --no-folding when there are exclusions to force
#      individual symlinks per file.
#   2. Stow 2.3.1's --ignore regex doesn't honor a leading `^` anchor
#      (empirically dropped/misinterpreted), so we anchor only at the end
#      with `\$` and escape literal dots in the basename.
read_mise_conf_excludes
STOW_EXTRA_ARGS=()
if ((${#MISE_CONF_EXCLUDED[@]} > 0)); then
    STOW_EXTRA_ARGS+=(--no-folding)
    for f in "${MISE_CONF_EXCLUDED[@]}"; do
        STOW_EXTRA_ARGS+=(--ignore="${f//./\\.}\$")
    done
fi

# Always restow: previously this branched on a `stow -nv` dry-run looking for
# LINK lines, which silently no-op'd the "already deployed but exclude set
# changed" case — leaving previously-linked conf.d files symlinked even after
# the user opted out of them. -R is idempotent on an already-correct tree, so
# we just run it unconditionally and only use the dry-run to detect blocking
# real-file conflicts that need to be backed up first.
stow_output="$(stow -nv -R -d "$HOME/.dotfiles/mise" "${STOW_EXTRA_ARGS[@]}" -t "$HOME" tag-default 2>&1)" || true

backup_mise_conflicts "$HOME/.dotfiles/mise/tag-default" "$HOME"
stow -d "$HOME/.dotfiles/mise" -R "${STOW_EXTRA_ARGS[@]}" -t "$HOME" tag-default 2>&1 \
    | { grep -v '^BUG in find_stowed_path' || true; }

if echo "$stow_output" | grep -qi "conflict"; then
    ok_changed "mise config deployed to ~/.config/mise/ (conflicts resolved via backup)"
else
    ok_changed "mise config deployed to ~/.config/mise/"
fi

# ─── Step 3: Optionally run full bootstrap ────────────────────────────────────

printf '\n'
if [[ "${DOTFILES_NONINTERACTIVE:-0}" == "1" ]]; then
    info "DOTFILES_NONINTERACTIVE=1 — running full bootstrap"
    mise run bootstrap
    exit 0
fi

read -rp $'\033[1;34m[INFO]\033[0m   Run full bootstrap now? [Y/n] ' answer
if [[ "${answer,,}" =~ ^(y|yes|)$ ]]; then
    mise run bootstrap
else
    info "Skipped. Run 'mise run bootstrap' when ready."
fi
