#!/usr/bin/env bash
#MISE description="Fast-forward every git submodule to its pinned branch and stage pointer changes"
#MISE raw=true
set -eo pipefail

DOTFILES_DIR="$(git -C "$(dirname "$0")" rev-parse --show-toplevel)"
TASK_NAME="update:submodules"

# Minimal local helpers (this task can run before mise config is stowed)
info() { printf '\033[1;34m[INFO]\033[0m \033[36m%-18s\033[0m ▸ %s\n' "$TASK_NAME" "$*"; }
warn() { printf '\033[1;33m[WARN]\033[0m \033[36m%-18s\033[0m ▸ %s\n' "$TASK_NAME" "$*"; }
ok() { printf '\033[1;32m[ OK ]\033[0m \033[36m%-18s\033[0m ▸ %s\n' "$TASK_NAME" "$*"; }
ok_changed() { printf '\033[1;32m[ OK ]\033[0m \033[36m%-18s\033[0m \033[1;32m●\033[0m %s\n' "$TASK_NAME" "$*"; }
fail() {
    printf '\033[1;31m[FAIL]\033[0m \033[36m%-18s\033[0m ▸ %s\n' "$TASK_NAME" "$*"
    exit 1
}

cd "$DOTFILES_DIR"

# Enumerate submodules from .gitmodules
mapfile -t SUBMODULE_PATHS < <(git config --file .gitmodules --get-regexp 'submodule\..*\.path' | awk '{print $2}')

if ((${#SUBMODULE_PATHS[@]} == 0)); then
    ok "No submodules configured"
    exit 0
fi

CHANGED_COUNT=0
CHANGED_PATHS=()

for sub_path in "${SUBMODULE_PATHS[@]}"; do
    info "Processing $sub_path"

    if [[ ! -e "$DOTFILES_DIR/$sub_path/.git" ]]; then
        warn "Submodule not initialized: $sub_path (run 'git submodule update --init') — skipping"
        continue
    fi

    # Resolve configured branch, falling back to master/main
    sub_name="$(git config --file .gitmodules --get-regexp "submodule\..*\.path" \
        | awk -v p="$sub_path" '$2 == p {gsub(/^submodule\./, "", $1); gsub(/\.path$/, "", $1); print $1; exit}')"
    branch="$(git config --file .gitmodules --get "submodule.${sub_name}.branch" 2>/dev/null || true)"

    pushd "$DOTFILES_DIR/$sub_path" >/dev/null

    if [[ -z "$branch" ]]; then
        # No branch pinned in .gitmodules — infer from remote HEAD
        git fetch --quiet origin
        branch="$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||')"
        branch="${branch:-master}"
        info "  No branch pinned in .gitmodules — using '$branch'"
    fi

    current_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
    if [[ "$current_branch" != "$branch" ]]; then
        info "  Switching from '$current_branch' to '$branch'"
        git checkout --quiet "$branch"
    fi

    before="$(git rev-parse HEAD)"
    git fetch --quiet origin "$branch"
    git merge --ff-only --quiet "origin/$branch"
    after="$(git rev-parse HEAD)"

    popd >/dev/null

    if [[ "$before" != "$after" ]]; then
        git add "$sub_path"
        ok_changed "$sub_path: ${before:0:7} → ${after:0:7}"
        CHANGED_PATHS+=("$sub_path")
        ((CHANGED_COUNT++))
    else
        ok "$sub_path already at latest $branch ($(git -C "$sub_path" describe --tags --always))"
    fi
done

printf '\n'
if ((CHANGED_COUNT > 0)); then
    ok_changed "Updated $CHANGED_COUNT submodule(s); pointer changes staged — review and commit:"
    for p in "${CHANGED_PATHS[@]}"; do
        printf '    git commit -m "chore(submodules): bump %s"\n' "$p"
    done
else
    ok "All submodules already current"
fi
