#!/usr/bin/env bash
#MISE description="Change the powerlevel10k OS icon (interactive)"
#MISE raw=true
set -eo pipefail

TASK_NAME="setup:p10k-icon"
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../lib/helpers.sh"

info "OS icon in p10k"
if [[ ! -e "$HOME/.p10k.zsh" && ! -L "$HOME/.p10k.zsh" ]]; then
    # shellcheck disable=SC2088 # user-visible path in a display string
    info "Skipping — ~/.p10k.zsh not found. Stow the p10k package or run 'p10k configure' first."
    exit 0
fi

printf 'Would you like to change the OS icon in p10k? (y/N): '
read -r CHANGE_ICON
if [[ ! "$CHANGE_ICON" =~ ^[Yy]$ ]]; then
    ok "OS icon unchanged"
    exit 0
fi

printf 'Browse icons at https://www.nerdfonts.com/cheat-sheet\n'
printf 'Paste your desired icon: '
read -r NEW_ICON
[[ -n "$NEW_ICON" ]] || {
    warn "No icon provided — skipping"
    exit 0
}

if ! prepare_p10k_file; then
    warn "Cannot modify p10k config"
    exit 0
fi

# Write to the resolved target if custom, otherwise ~/.p10k.zsh
P10K_FILE="${P10K_CUSTOM_TARGET:-$HOME/.p10k.zsh}"
if [[ ! -f "$P10K_FILE" ]]; then
    warn ".p10k.zsh not found — run p10k configure first"
    exit 0
fi

# Replace CONTENT_EXPANSION in-place (don't depend on BACKGROUND existing)
awk -v icon="$NEW_ICON" '
    /POWERLEVEL9K_OS_ICON_CONTENT_EXPANSION/ {
        match($0, /^[[:space:]]*/);
        indent = substr($0, RSTART, RLENGTH);
        print indent "typeset -g POWERLEVEL9K_OS_ICON_CONTENT_EXPANSION=\047" icon "\047";
        found = 1;
        next
    }
    { print }
    END {
        if (!found) print "WARNING: POWERLEVEL9K_OS_ICON_CONTENT_EXPANSION not found in .p10k.zsh" > "/dev/stderr"
    }
' "$P10K_FILE" >"${P10K_FILE}.tmp" && mv -f "${P10K_FILE}.tmp" "$P10K_FILE"
ok_changed "OS icon updated in .p10k.zsh"
sync_custom_p10k
