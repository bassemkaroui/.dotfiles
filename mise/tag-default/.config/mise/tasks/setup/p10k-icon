#!/usr/bin/env bash
#MISE description="Change the powerlevel10k OS icon (interactive)"
#MISE raw=true
set -eo pipefail

TASK_NAME="setup:p10k-icon"
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../lib/helpers.sh"

# The icon override lives in ~/.p10k.local.zsh, sourced by ~/.zshrc *after*
# ~/.p10k.zsh. Writing here (instead of editing ~/.p10k.zsh) keeps the stowed
# .p10k.zsh symlink intact across runs and survives `p10k configure`
# regenerations of the main file.
P10K_LOCAL="$HOME/.p10k.local.zsh"

info "OS icon in p10k"
if [[ "${DOTFILES_NONINTERACTIVE:-0}" == "1" ]]; then
    ok "OS icon unchanged (DOTFILES_NONINTERACTIVE)"
    exit 0
fi
printf 'Would you like to change the OS icon in p10k? (y/N): '
read -r CHANGE_ICON
if [[ ! "$CHANGE_ICON" =~ ^[Yy]$ ]]; then
    ok "OS icon unchanged"
    exit 0
fi

printf 'Browse icons at https://www.nerdfonts.com/cheat-sheet\n'
printf 'Paste your desired icon: '
read -r NEW_ICON
[[ -n "$NEW_ICON" ]] || {
    warn "No icon provided — skipping"
    exit 0
}

NEW_LINE="typeset -g POWERLEVEL9K_OS_ICON_CONTENT_EXPANSION='${NEW_ICON}'"

if [[ -f "$P10K_LOCAL" ]] \
    && grep -q '^[[:space:]]*typeset -g POWERLEVEL9K_OS_ICON_CONTENT_EXPANSION=' "$P10K_LOCAL"; then
    tmpfile="$(mktemp)"
    awk -v repl="$NEW_LINE" '
        /^[[:space:]]*typeset -g POWERLEVEL9K_OS_ICON_CONTENT_EXPANSION=/ { print repl; next }
        { print }
    ' "$P10K_LOCAL" >"$tmpfile" && mv -f "$tmpfile" "$P10K_LOCAL"
else
    if [[ ! -f "$P10K_LOCAL" ]]; then
        printf '# Per-machine p10k overrides (gitignored, sourced from ~/.zshrc)\n' \
            >"$P10K_LOCAL"
    fi
    printf '%s\n' "$NEW_LINE" >>"$P10K_LOCAL"
fi

ok_changed "OS icon override written to $P10K_LOCAL"
